@page "/"
@using Test1.Models

<PageTitle>Home</PageTitle>

<h1>Produkt číslo 1</h1>
<br />
Jméno
<input type="text" @bind-value="produkt_1.Jmeno" @bind-value:event="oninput" placeholder="Zadejte název produktu"/>
<br />
Cena
<input type="number" @bind-value="produkt_1.Cena" />
<br />
Množství
<input type="number" @bind-value="produkt_1.Mnozství" />
<br />
@if (produkt_1.ErrorMessage != "")
{
    <div class="alert alert-danger" role="alert">
        @produkt_1.ErrorMessage;
    </div>
}

<h1>Produkt číslo 2</h1>
<br />

Jméno
<input type="text" @bind-value="produkt_2.Jmeno" @bind-value:event="oninput" placeholder="Zadejte název produktu" />
<br />
Cena
<input type="number" @bind-value="produkt_2.Cena"  />
<br />
Množství
<input type="number" @bind-value="produkt_2.Mnozství"  />
@if(produkt_2.ErrorMessage!=""){
    <div class="alert alert-danger" role="alert">
        @produkt_1.ErrorMessage;
    </div>
}
<br />



<h1>Porovnaní</h1>
<label>Celková hodnota produktu 1 -	<input value="@text1" readonly /></label>
<br />
<label>Celková hodnota produktu 1 -	<input value="@text2" readonly /></label>
<br />
@if (produkt_1.TotalValue > produkt_2.TotalValue)
{
    <p>Produkt jedna je dražší o @rozdil1 než produkt 2</p>
    <p>Podíl produktu 1 ku produktu 2 je: @podil1</p>
    <p>Podíl produktu 2 ku produktu 1 je: @podil2</p>

}else{
    <p>Produkt jedna je dražší o @rozdil2 než produkt 2</p>
    <p>Podíl produktu 2 ku produktu 1 je: @podil1</p>
    <p>Podíl produktu 2 ku produktu 1 je: @podil2</p>

}



@code {
    ProduktClass produkt_1 = new ProduktClass();
    ProduktClass produkt_2 = new ProduktClass();
    
    string text1 => produkt_1.Jmeno == "" ? "Název produktu" + ": " + produkt_1.TotalValue : (produkt_1.Jmeno + ": " + produkt_1.TotalValue);
    string text2 => produkt_2.Jmeno == "" ? "Název produktu" + ": " + produkt_2.TotalValue : (produkt_2.Jmeno + ": " + produkt_2.TotalValue);
    double rozdil1 => produkt_1.TotalValue - produkt_2.TotalValue;
    double rozdil2 => produkt_2.TotalValue - produkt_1.TotalValue;
    double podil1 => produkt_1.TotalValue/ produkt_2.TotalValue;
    double podil2 => produkt_2.TotalValue/ produkt_1.TotalValue;

}    